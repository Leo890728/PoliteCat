#: bot\cogs\util\player.py:on_wavelink_track_start:command response
msgid "正在播放"
msgstr "Now playing"

#: bot\cogs\util\player.py:on_wavelink_track_start:command response
msgid "時長"
msgstr "length"

#: bot\cogs\util\player.py:on_wavelink_track_start:command response
msgid "\n\n`此歌曲由 {source} 推薦`"
msgstr "\n\n`This track was recommended via {source}`"

