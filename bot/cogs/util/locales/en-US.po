msgid "下一首 » {next_track_title}"
msgstr "Next track » {next_track_title}"

#: bot\cogs\util\player.py:play:command name
msgid "播放"
msgstr "play"

#: bot\cogs\util\player.py:play:command description
msgid "播放音樂、串流或播放清單"
msgstr "Play a music track, stream, or playlist"

#: bot\cogs\util\player.py:play:option name
msgid "搜尋詞"
msgstr "search-term"

#: bot\cogs\util\player.py:play:option description
msgid "想播放的歌曲或播放列表（可以是名稱、網址，或搜尋詞）"
msgstr "The song or playlist you want to play (can be a name, URL, or search term)"

#: bot\cogs\util\player.py:play:option name
msgid "推薦列表"
msgstr "recommended list"

#: bot\cogs\util\player.py:play:option description
msgid "啟用或停用自動推薦播放列表功能（預設為停用）"
msgstr "Enable or disable automatic recommendations for the queue (default: disabled)"

#: bot\cogs\util\player.py:skip:command name
msgid "跳過"
msgstr "skip"

#: bot\cogs\util\player.py:skip:command description
msgid "跳過目前曲目"
msgstr "Skip the current track"

#: bot\cogs\util\player.py:queue:command name
msgid "待播清單"
msgstr "queue"

#: bot\cogs\util\player.py:queue:command description
msgid "顯示待播清單"
msgstr "Show the track queue"

#: bot\cogs\util\player.py:filter:command name
msgid "調音器"
msgstr "equalizer"

#: bot\cogs\util\player.py:filter:command description
msgid "Set the filter to a other style"
msgstr "Set the filter to another style"

#: bot\cogs\util\player.py:filter:command name
msgid "調音模式"
msgstr "equalizer-mode"

#: bot\cogs\util\player.py:filter:command description
